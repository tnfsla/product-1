# ----------------------------------------------------------------------------
# Maven Start Up Batch Script
#
# This script executes the Maven toolkit.
#
# $Id: mvn.bat 1374528 2012-08-19 20:07:05Z hboutemy $
# ----------------------------------------------------------------------------

# Helper to locate the mvn executable
# Will find the first match of mvn.cmd (Windows) or mvn (Unix/Linux/MacOS)
# along the PATH, and then derive MVN_HOME based on that.
find_mvn_exec() {
    local candidate
    local -a candidates
    # Find all candidates on the PATH (same as what `which -a mvn` would do)
    while IFS=: read -r -d "" -a PATH_ELEMENTS ; do
        for PATH_ELEMENT in "${PATH_ELEMENTS[@]}" ; do
            if [ -x "$PATH_ELEMENT/mvn.cmd" ] ; then # Windows
                candidates+=( "$PATH_ELEMENT/mvn.cmd" )
            elif [ -x "$PATH_ELEMENT/mvn" ] ; then # Unix/Linux/MacOS
                candidates+=( "$PATH_ELEMENT/mvn" )
            fi
        done
    done < <(printf '%s\0' "$PATH")

    if [ ${#candidates[@]} -gt 0 ] ; then
        MVN_EXEC="${candidates[0]}"
        MVN_HOME=$(dirname "$MVN_EXEC")
    else
        echo "Error: Could not find 'mvn' executable on PATH." >&2
        return 1
    fi
    return 0
}

# OS specific support.  $var _must_ be set to unix/dos style path
#
case "`uname`" in
  CYGWIN*) cygwin=true ;;
  MINGW*) mingw=true ;;
  Darwin*) darwin=true ;;
esac

# ----------------------------------------------------------------------------
# Setup MAVEN_HOME
# ----------------------------------------------------------------------------
if [ -z "$MAVEN_HOME" ] ; then
  ## resolve links - $0 may be a softlink
  PRG="$0"

  while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
      PRG="$link"
    else
      PRG=`dirname "$PRG"`/"$link"
    fi
  done

  CWD=`pwd`
  PRG_DIR=`dirname "$PRG"`
  cd "$PRG_DIR"
  BASEDIR=`pwd`
  cd "$CWD"

  # get the full path (without any relative segments)
  MAVEN_HOME=`cd "$BASEDIR/.." ; pwd`

  # make it DOS-friendly if we're on Windows
  if $cygwin ; then
    MAVEN_HOME=`cygpath --windows "$MAVEN_HOME"`
  elif $mingw ; then
    MAVEN_HOME=`cmd //c echo "$MAVEN_HOME"`
  fi
fi

# Attempt to find the mvn executable if MAVEN_HOME is not set
if [ -z "$MAVEN_HOME" ] ; then
    if find_mvn_exec ; then
        echo "Using mvn found on PATH: $MVN_EXEC"
    else
        exit 1
    fi
fi

# ----------------------------------------------------------------------------
# Set up the classpath
# ----------------------------------------------------------------------------
MAVEN_CLASSPATH="$MAVEN_HOME/boot/plexus-classworlds-*.jar"

# ----------------------------------------------------------------------------
# Set up the command line
# ----------------------------------------------------------------------------
MAVEN_CMD_LINE_ARGS="$@"

# For Maven 2.x, the MAVEN_OPTS should be specified in the mavenrc file.
# For example:
# export MAVEN_OPTS="-Xms128m -Xmx512m"
if [ -z "$MAVEN_OPTS" ] ; then
    MAVEN_OPTS="-Xms256m -Xmx512m"
fi

# For Maven 3.x, use `MAVEN_DEBUG_OPTS` to set debug options.
# For example:
# export MAVEN_DEBUG_OPTS="-Xrunjdwp:transport=dt_socket,server=y,suspend=n,address=8000"
#
# For Maven 2.x, use `MAVEN_DEBUG_OPTS` to set debug options.
# For example:
# export MAVEN_DEBUG_OPTS="-Xdebug -Xnoagent -Djava.compiler=NONE -Xrunjdwp:transport=dt_socket,server=y,suspend=n,address=8000"

if [ -n "$MAVEN_DEBUG_OPTS" ] ; then
    MAVEN_OPTS="$MAVEN_OPTS $MAVEN_DEBUG_OPTS"
fi

# Run the Maven command
# If MAVEN_HOME is set, use that; otherwise, rely on `mvn` being on PATH
if [ -n "$MAVEN_HOME" ] ; then
    exec "$JAVA_HOME/bin/java" $MAVEN_OPTS \
      -classpath "$MAVEN_CLASSPATH" \
      -Dmaven.home="$MAVEN_HOME" \
      -Dmaven.multiModuleProjectDirectory="$MAVEN_HOME" \
      org.codehaus.plexus.classworlds.launcher.Launcher \
      $MAVEN_CMD_LINE_ARGS
else
    exec "mvn" $MAVEN_CMD_LINE_ARGS
fi
